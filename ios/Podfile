# React Native 0.82 compatible Podfile
platform :ios, '16.0'

require_relative '../node_modules/react-native/scripts/react_native_pods'
# require_relative '../node_modules/@react-native-community/cli-platform-ios/native_modules'

prepare_react_native_project!

use_frameworks! :linkage => :static # static linking avoids further conflicts
$RNFirebaseAsStaticFramework = true

target 'CoachiatryApp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # Fix fmt consteval errors with Xcode 26+ / newer Clang.
    # Force every FMT_USE_CONSTEVAL definition in base.h to 0 — fmt's auto-detect
    # picks 1 on modern Apple Clang, but consteval format strings then fail to
    # constant-evaluate when fmt is built as a static framework.
    fmt_base = File.join(__dir__, 'Pods', 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      patched = content.gsub(/^(#\s*define\s+FMT_USE_CONSTEVAL)\s+1\b/, '\1 0')
      File.write(fmt_base, patched) if patched != content
    end

    # Xcode 16+ ships with strict user-script sandboxing that conflicts with
    # the [CP-User] [RNFB] Core Configuration script and creates a build
    # cycle when an app extension (e.g. Notification Service Extension) is
    # embedded. Disable sandboxing for every native target we manage.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      end
    end
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.native_targets.each do |target|
        target.build_configurations.each do |config|
          config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        end
      end
      aggregate_target.user_project.save
    end
  end
end
